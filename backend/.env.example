# Server Configuration
NODE_ENV=development
PORT=3000

# Clerk Authentication - GET THESE FROM YOUR CLERK DASHBOARD
# Sign up at https://clerk.com and create an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=put_key_here
CLERK_SECRET_KEY=put_key_here


# MongoDB (optional for Phase 1, required for Phase 2)
MONGODB_URI=mongodbURI_here

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19000,http://localhost:3001

# JWT Secret (only used if falling back to dev mode)
JWT_SECRET=your_jwt_secret_key_here

